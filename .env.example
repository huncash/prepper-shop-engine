# Shared session signing (auth-service + admin-api) — min 16 chars
SESSION_SECRET=replace-with-long-random-secret

# AES-256-GCM for encrypted private files (signatures, etc.) — min 16 chars
# Or 64 hex chars for a raw 32-byte key
SECRET_KEY=replace-with-long-random-secret

# Local/dev admin credentials (bcrypt hash). Password used for hash generation: set your own.
AUTH_ADMIN_EMAIL=admin@localhost
AUTH_ADMIN_PASSWORD_HASH=
AUTH_ADMIN_ROLE=admin

# Optional JSON array alternative: [{"id":"...","email":"...","role":"admin","passwordHash":"..."}]
# AUTH_USERS=

# Optional partner / customer store (users + saved carts)
# PARTNER_STORE_PATH=./private_data/partner_store.json


# Browser origins allowed to call auth with credentials
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
