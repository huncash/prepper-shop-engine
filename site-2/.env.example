# site-2 (projektorlampacsere) — helyi fejlesztés
NEXT_PUBLIC_SITE_ID=site-2

# Session JWT (min 16 karakter) — auth cookie aláírás
SESSION_SECRET=dev-session-secret-change-me
AUTH_COOKIE_SECURE=false

# Ügyvezetői admin (bcrypt hash).
# FIGYELEM: a bcrypt hash $-jeleit escape-eld (\$), különben az env loader „megevzi” őket!
#   node -e "console.log(require('bcryptjs').hashSync('YOUR_PASSWORD',10))"
# Példa: AUTH_ADMIN_PASSWORD_HASH=\$2b\$10\$...
AUTH_ADMIN_EMAIL=admin@localhost
AUTH_ADMIN_PASSWORD_HASH=
AUTH_ADMIN_ROLE=admin

# Relatív a site-2 munkakönyvtárához (next dev cwd = site-2/)
PRODUCTS_DB_PATH=./private_data/source_data.json

# Opcionális külső auth szolgáltatás (ha külön fut)
NEXT_PUBLIC_AUTH_URL=http://localhost:4001
API_URL=http://localhost:4000
AUTH_URL=http://localhost:4001
