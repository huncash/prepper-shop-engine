{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": "..",
    "paths": {
      "@shared/components/*": ["./shared-core/src/components/*"],
      "@shared/lib/*": ["./shared-core/lib/*"],
      "@shared/auth/*": ["./shared-core/auth/*"],
      "@shared/templates/*": ["./shared-core/templates/*"],
      "@shared/config/*": ["./shared-core/src/config/*"],
      "@shared/*": ["./shared-core/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
