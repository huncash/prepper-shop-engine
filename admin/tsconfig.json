{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "baseUrl": "..",
    "paths": {
      "@shared/lib/*": ["./shared-core/lib/*"],
      "@shared/auth/*": ["./shared-core/auth/*"],
      "@shared/*": ["./shared-core/src/*"]
    }
  },
  "include": ["src"]
}
